{
  "name": "girky",
  "version": "1.31.3",
  "description": "Create a Girk site from Markdown",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "girk": "dist/index.js",
    "gieter": "dist/index.js"
  },
  "type": "commonjs",
  "engines": {
    "node": "^20.19.0 || >=22.12.0 <26"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./sdk": {
      "types": "./node_modules/girk-sdk/dist/index.d.ts",
      "default": "./node_modules/girk-sdk/dist/index.js"
    }
  },
  "scripts": {
    "build": "npm run build:style && npm run build:ts",
    "build:ts": "tsc && tsc-alias",
    "build:full": "rimraf dist && rimraf .cache && npm run build && npm run test",
    "build:style": "sass src/style/app.scss dist/style/app.css --load-path=node_modules --load-path=../../node_modules --style=compressed --no-source-map",
    "dev:style": "sass src/style/app.scss dist/style/app.css --load-path=node_modules --load-path=../../node_modules --watch --error-css --style=expanded",
    "style:clean": "rm -rf .cache && rm -rf dist/style/app.css",
    "dev": "concurrently --kill-others \"tsc -w\" \"tsc-alias -w\" \"npm run dev:style\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src --tsconfig tsconfig.json",
    "lint:fix": "oxlint src --tsconfig tsconfig.json --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepublishOnly": "npm run build:full"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvandiepen/girk.git"
  },
  "keywords": [
    "open",
    "letter",
    "generate"
  ],
  "author": "Sil van Diepen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/silvandiepen/girk/issues"
  },
  "homepage": "https://github.com/silvandiepen/girk#readme",
  "files": [
    "dist",
    "src/template",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/sass": "^1.43.1",
    "@types/sharp": "^0.31.1",
    "concurrently": "^7.6.0",
    "husky": "^8.0.3",
    "nodemon": "^2.0.21",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsc-alias": "^1.8.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "watch": "^1.0.2"
  },
  "dependencies": {
    "@sil/args": "^0.0.6",
    "@sil/case": "^0.0.5",
    "@sil/colorset": "^0.0.8",
    "@sil/format": "^0.0.9",
    "cli-block": "^1.4.1",
    "express": "^4.18.2",
    "fs-extra": "^11.1.0",
    "girk-sdk": "^1.25.4",
    "iconator": "^0.3.2",
    "mv": "^2.1.1",
    "nizel": "^0.1.12",
    "nizel-plugin-abbr": "^0.1.10",
    "nizel-plugin-alert": "^0.1.11",
    "nizel-plugin-autolink": "^0.1.11",
    "nizel-plugin-badge": "^0.1.0",
    "nizel-plugin-citations": "^0.1.10",
    "nizel-plugin-code-copy": "^0.1.11",
    "nizel-plugin-deflist": "^0.1.11",
    "nizel-plugin-details": "^0.1.10",
    "nizel-plugin-diagrams": "^0.1.10",
    "nizel-plugin-emoji": "^0.1.11",
    "nizel-plugin-footnotes": "^0.1.10",
    "nizel-plugin-frontmatter-ui": "^0.1.10",
    "nizel-plugin-heading-anchors": "^0.1.10",
    "nizel-plugin-kbd": "^0.1.0",
    "nizel-plugin-math": "^0.1.10",
    "nizel-plugin-media": "^0.1.10",
    "nizel-plugin-open-icon": "^0.1.0",
    "nizel-plugin-print": "^0.1.0",
    "nizel-plugin-sanitize": "^0.1.10",
    "nizel-plugin-shiki": "^0.1.12",
    "nizel-plugin-task-list": "^0.1.2",
    "nizel-plugin-toc": "^0.1.10",
    "nizel-plugin-typography": "^0.1.10",
    "nizel-style": "^0.1.1",
    "open-icon": "^1.1.3",
    "rimraf": "^4.3.0",
    "sass": "^1.98.0",
    "sharp": "^0.31.3"
  }
}
