footer.footer 
    .footer__container
        if menu.length > 0
            .footer__navigation
                - const navigationVariant = "footer"
                - const navigationIdPrefix = "footer-navigation"
                include navigation.pug

        if logo || langMenu.length > 1
            .footer__bar
                if logo
                    .footer__brand
                        - const logoVariant = "footer"
                        include logo.pug

                .footer__controls
                    if langMenu.length > 1
                        .footer__control
                            span.footer__label Language
                            ul.language
                                each language in langMenu
                                    li.language__item(class= `${language.active ? 'language__item--active' : ''}`)
                                        a.language__link(href=`${language.link}`,data-title=`${language.title}`,data-code=`${language.code}`,data-name=`${language.name}`)
                                            span.language__text=language.code

                    .footer__control
                        button.color-mode-toggle(type="button", data-color-mode-toggle, aria-label="Toggle color mode", aria-pressed="false")
                            span.color-mode-toggle__option Light
                            span.color-mode-toggle__track(aria-hidden="true")
                                span.color-mode-toggle__thumb
                            span.color-mode-toggle__option Dark
        else
            .footer__bar.footer__bar--end
                .footer__controls
                    .footer__control
                        button.color-mode-toggle(type="button", data-color-mode-toggle, aria-label="Toggle color mode", aria-pressed="false")
                            span.color-mode-toggle__option Light
                            span.color-mode-toggle__track(aria-hidden="true")
                                span.color-mode-toggle__thumb
                            span.color-mode-toggle__option Dark

        if config.copyright || (socials && socials.length)
            .footer__meta
                if config.copyright
                    div.copyright
                        | !{config.copyright}
                if socials && socials.length
                    ul.socials
                        each social in socials
                            li.socials__item
                                a.socials__link(href=`${social.link}`,aria-label=`${social.title}`,title=`${social.title}`)
                                    span.socials__text=social.title

if project.script
    each script in project.script
        script(lang="text/javascript", src=script.src, type=script.type)
