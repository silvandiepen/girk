main.main(class=`${meta.type ? 'content--'+ meta.type : ''}`)
    section.section
        div.container
            div.content
                if subtitle
                    h6=subtitle
                if showContentImage
                    h1=title
                    figure
                        img(src=meta.image)
                    | !{removeTitle(content)}  
                else 
                    | !{content}  

    if relatedPages && relatedPages.length
        section.section.section--related
            div.container
                div.content
                    if parentPage
                        h6= parentPage.title
                    h2 More Pages
                ul.archive-grid
                    each item in relatedPages
                        li.archive-card
                            a.archive-card__link(href=`${item.redirect ? item.redirect : item.link}`)
                                if item.meta.icon
                                    span.archive-card__media.archive-card__media--icon
                                        img.archive-card__icon(src=item.meta.icon, alt="")
                                .archive-card__body
                                    h3.archive-card__title= item.title
                                    if item.excerpt
                                        p.archive-card__excerpt
                                            | !{item.excerpt}

    if archives.length
        include archive.pug
        
    if tags.length
        include tags.pug
