-
    const variant = typeof logoVariant !== "undefined" ? ` logo--${logoVariant}` : ""
if project
    if logo
        if logo.data
            a.logo(href=`${homeLink}`, class=`${logo.data ? 'logo--image-only' : ''}${variant}`, aria-label=`${project.title}`)
                | !{logo.data}
        else if logo.relativePath
            a.logo(href=`${homeLink}`, class=variant, aria-label=`${project.title}`)
                img(src=logo.relativePath)
    else if project.title
        a.logo.logo--title(href=`${homeLink}`, class=variant)
            span.logo__text=project.title
