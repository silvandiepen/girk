include icon.pug

section.section.archive.archive--articles
    div.container
        if archive.title
            .content
                h2.h4= archive.title
        ul.archive-grid
            each item in archive.children
                li.archive-card
                    a.archive-card__link(href=`${item.redirect ? item.redirect : item.link}`)
                        if item.icon
                            +renderIcon(item.icon, "archive-card__media archive-card__media--icon", "archive-card__icon")
                        .archive-card__body
                            h3.archive-card__title= item.title
                            if item.excerpt
                                p.archive-card__excerpt
                                    | !{item.excerpt}
