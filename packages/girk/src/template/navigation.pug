mixin renderNavigation(items, level)
    ul(class=`navigation__list${level > 0 ? ' navigation__list--sub' : ''}`)
        each item in items
            li.navigation__item(class= `${item.current ? 'navigation__item--current' : ''}${item.isParent && !item.current ? ' navigation__item--parent' : ''}${item.children && item.children.length ? ' navigation__item--has-children' : ''}`)
                a.navigation__link(href=item.link)
                    span.navigation__text= item.name
                if item.children && item.children.length
                    +renderNavigation(item.children, level + 1)

nav.navigation(id="site-navigation")
    +renderNavigation(menu, 0)
