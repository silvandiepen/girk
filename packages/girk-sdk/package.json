{
  "name": "girk-sdk",
  "version": "1.28.0",
  "description": "Girk SDK — build static sites from in-memory data",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0 <26"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src --tsconfig tsconfig.json",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvandiepen/girk.git",
    "directory": "packages/girk-sdk"
  },
  "keywords": [
    "static-site",
    "generator",
    "sdk",
    "markdown"
  ],
  "author": "Sil van Diepen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/silvandiepen/girk/issues"
  },
  "homepage": "https://github.com/silvandiepen/girk#readme",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@sil/case": "^0.0.5",
    "nizel": "^0.1.0",
    "nizel-plugin-alert": "^0.1.0",
    "nizel-plugin-deflist": "^0.1.0",
    "nizel-plugin-emoji": "^0.1.0",
    "nizel-plugin-shiki": "^0.1.0",
    "shiki": "^3.0.0",
    "open-icon": "^1.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsc-alias": "^1.8.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
