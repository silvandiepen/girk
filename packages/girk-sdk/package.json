{
  "name": "girk-sdk",
  "version": "0.1.0",
  "description": "Girk SDK — build static sites from in-memory data",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "commonjs",
  "engines": {
    "node": "^20.19.0 || >=22.12.0 <26"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint src --tsconfig tsconfig.json",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/silvandiepen/girk.git",
    "directory": "packages/girk-sdk"
  },
  "keywords": [
    "static-site",
    "generator",
    "sdk",
    "markdown"
  ],
  "author": "Sil van Diepen",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/silvandiepen/girk/issues"
  },
  "homepage": "https://github.com/silvandiepen/girk#readme",
  "files": [
    "dist",
    "src/template",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@sil/case": "^0.0.5",
    "date-fns": "^2.29.3",
    "markdown-it": "^13.0.1",
    "markdown-it-alert": "^0.1.5",
    "markdown-it-anchor": "^8.6.7",
    "markdown-it-deflist": "^2.1.0",
    "markdown-it-emoji": "^2.0.2",
    "markdown-it-highlightjs": "^4.0.1",
    "markdown-it-prism": "^2.3.0",
    "markdown-it-tasks": "^0.0.5",
    "node-fetch": "^2.6.1",
    "open-icon": "^1.1.3",
    "pug": "^3.0.2",
    "purgecss": "^5.0.0",
    "sass": "^1.98.0",
    "svgo": "^3.0.2"
  },
  "devDependencies": {
    "@types/markdown-it": "^12.2.3",
    "@types/node": "^25.5.0",
    "@types/node-fetch": "^3.0.2",
    "@types/pug": "^2.0.6",
    "@types/sass": "^1.43.1",
    "@types/svgo": "^2.6.4",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "tsc-alias": "^1.8.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0"
  }
}
