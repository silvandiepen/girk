if has.search
    .search-shell(hidden data-search-shell)
        button.search-shell__backdrop(type="button" aria-label="Close search" data-search-close tabindex="-1")
        .search-shell__dialog(
            id="site-search"
            role="dialog"
            aria-modal="true"
            aria-labelledby="site-search-title"
            data-search-scope=searchContext.scope
            data-search-page-id=searchContext.pageId
            data-search-branch=searchContext.branch
            data-search-dialog
        )
            form.search-shell__panel(role="search" novalidate data-search-form)
                h2.search-shell__title(id="site-search-title") Search
                label.search-shell__field(for="site-search-input")
                    span.search-shell__field-icon(aria-hidden="true")
                        svg.search-shell__field-icon-asset(viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round")
                            circle(cx="11" cy="11" r="6.5")
                            line(x1="16" y1="16" x2="21" y2="21")
                    input#site-search-input.search-shell__input(
                        type="search"
                        autocomplete="off"
                        autocapitalize="off"
                        spellcheck="false"
                        placeholder="Search this site"
                        enterkeyhint="search"
                        data-search-input
                    )
                    button.search-shell__close(type="button" aria-label="Close search" data-search-close)
                        span.search-shell__close-icon(aria-hidden="true")
                p.search-shell__hint Search pages in this site. Results update while you type.
                .search-shell__results.search-results(data-search-results hidden)
